<Window x:Class="WordCheckerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WordCheckerWPF"
        mc:Ignorable="d"
        Title="Word Checker" Height="800" Width="1000"
        Background="#F5F5F5"
        Closing="Window_Closing">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Margin="10">
            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,15">
                <TextBlock Text="Word Checker Application" FontSize="24" FontWeight="Bold" Foreground="#333"/>
                <TextBlock Text="Search for forbidden words in files across all drives" FontSize="12" Foreground="#666" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Input Section -->
            <Border DockPanel.Dock="Top" Background="White" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Configuration" FontSize="14" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Input File (Forbidden Words):" FontSize="11" Foreground="#555" Margin="0,0,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="InputFileTextBox" Grid.Column="0" Padding="8" BorderThickness="1" BorderBrush="#DDD" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Browse..." Click="BrowseInputFile_Click" Margin="5,0,0,0" Padding="15,5" Background="#007ACC" Foreground="White" Cursor="Hand"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Output Directory:" FontSize="11" Foreground="#555" Margin="0,0,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="OutputDirTextBox" Grid.Column="0" Padding="8" BorderThickness="1" BorderBrush="#DDD" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Browse..." Click="BrowseOutputDir_Click" Margin="5,0,0,0" Padding="15,5" Background="#007ACC" Foreground="White" Cursor="Hand"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Log Directory:" FontSize="11" Foreground="#555" Margin="0,0,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="LogDirTextBox" Grid.Column="0" Padding="8" BorderThickness="1" BorderBrush="#DDD" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Browse..." Click="BrowseLogDir_Click" Margin="5,0,0,0" Padding="15,5" Background="#007ACC" Foreground="White" Cursor="Hand"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Progress Section -->
            <Border DockPanel.Dock="Top" Background="White" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Search Progress" FontSize="14" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>

                    <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="DriveProgressItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DriveName}" FontSize="11" FontWeight="Bold" Foreground="#333"/>
                                            <ProgressBar Height="20" Value="{Binding Progress}" Maximum="100" Foreground="#28A745" Margin="0,3,0,5"/>
                                            <TextBlock Text="{Binding Status}" FontSize="10" Foreground="#666"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Control Buttons -->
            <Border DockPanel.Dock="Top" Background="White" Padding="15" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="StartButton" Content="Start Search" Click="Start_Click" Padding="20,10" Background="#28A745" Foreground="White" FontWeight="Bold" Cursor="Hand" Margin="0,0,10,0"/>
                    <Button x:Name="PauseButton" Content="Pause" Click="Pause_Click" Padding="20,10" Background="#FFC107" Foreground="White" FontWeight="Bold" Cursor="Hand" Margin="0,0,10,0" IsEnabled="False"/>
                    <Button x:Name="ResumeButton" Content="Resume" Click="Resume_Click" Padding="20,10" Background="#17A2B8" Foreground="White" FontWeight="Bold" Cursor="Hand" Margin="0,0,10,0" IsEnabled="False"/>
                    <Button x:Name="StopButton" Content="Stop" Click="Stop_Click" Padding="20,10" Background="#DC3545" Foreground="White" FontWeight="Bold" Cursor="Hand" IsEnabled="False"/>
                </StackPanel>
            </Border>

            <!-- Results Section -->
            <Border Background="White" Padding="15">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Results" FontSize="14" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>
                    <ScrollViewer>
                        <StackPanel>
                            <TextBlock x:Name="ResultsTextBlock" Text="Results will appear here after search completes..." Foreground="#666" TextWrapping="Wrap" LineHeight="20"/>
                            <DataGrid x:Name="ResultsDataGrid" Margin="0,10,0,0" AutoGenerateColumns="True" IsReadOnly="True" Background="#F9F9F9"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </DockPanel>

        <!-- Right Sidebar - Statistics -->
        <Border Grid.Column="1" Background="White" Padding="15" Margin="0,10,10,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Statistics" FontSize="14" FontWeight="Bold" Foreground="#333" Margin="0,0,0,15"/>

                <ScrollViewer DockPanel.Dock="Top">
                    <StackPanel>
                        <!-- Total Files Found -->
                        <Border Background="#E7F3FF" Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Files Found" FontSize="11" Foreground="#0056B3" FontWeight="Bold"/>
                                <TextBlock x:Name="TotalFilesTextBlock" Text="0" FontSize="28" FontWeight="Bold" Foreground="#0056B3" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Total Matches -->
                        <Border Background="#F0F3BD" Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Total Forbidden Words Found" FontSize="11" Foreground="#856404" FontWeight="Bold"/>
                                <TextBlock x:Name="TotalMatchesTextBlock" Text="0" FontSize="28" FontWeight="Bold" Foreground="#856404" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Unique Words -->
                        <Border Background="#F8D7DA" Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Unique Words" FontSize="11" Foreground="#721C24" FontWeight="Bold"/>
                                <TextBlock x:Name="UniqueWordsTextBlock" Text="0" FontSize="28" FontWeight="Bold" Foreground="#721C24" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Execution Time -->
                        <Border Background="#D1ECF1" Padding="12" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Execution Time" FontSize="11" Foreground="#0C5460" FontWeight="Bold"/>
                                <TextBlock x:Name="ExecutionTimeTextBlock" Text="0.0 sec" FontSize="20" FontWeight="Bold" Foreground="#0C5460" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Top 10 Words -->
                        <TextBlock Text="Top 10 Words" FontSize="12" FontWeight="Bold" Foreground="#333" Margin="0,10,0,10"/>
                        <ListBox x:Name="TopWordsListBox" Height="300" Background="#F9F9F9" BorderThickness="1" BorderBrush="#DDD">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Key}" Foreground="#333"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="#666" FontWeight="Bold" Margin="10,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
